<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Allow unsigned executable memory for V8 JavaScript engine -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>

	<!-- Allow JIT compilation (required for V8) -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>

	<!-- Disable library validation to allow dynamic loading -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- Network access entitlements -->
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>

	<!-- USB device access for external security keys (FIDO2/WebAuthn) -->
	<key>com.apple.security.device.usb</key>
	<true/>

	<!-- Bluetooth access for wireless security keys -->
	<key>com.apple.security.device.bluetooth</key>
	<true/>

	<!-- Camera access (for Google Meet/Chat video calls) -->
	<key>com.apple.security.device.camera</key>
	<true/>

	<!-- Microphone access (for Google Meet/Chat audio calls) -->
	<key>com.apple.security.device.audio-input</key>
	<true/>

	<!-- Allow outgoing network connections -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- User-selected files (for file uploads in Google Chat) -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>

	<!-- Downloads folder access (for file downloads) -->
	<key>com.apple.security.files.downloads.read-write</key>
	<true/>

	<!-- Allow printing -->
	<key>com.apple.security.print</key>
	<true/>
</dict>
</plist>

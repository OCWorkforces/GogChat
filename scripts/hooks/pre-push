#!/bin/bash

# Pre-push hook for GChat
# Runs linting checks before allowing a push
# If linting fails, the push will be blocked

set -e

echo ""
echo "🔍 Running linting checks before push..."
echo ""

# Run the linting script
if bun run lint:all; then
  echo ""
  echo "✅ All linting checks passed. Proceeding with push..."
  echo ""
  exit 0
else
  echo ""
  echo "❌ Linting checks failed. Push blocked."
  echo "💡 Fix the issues manually or run: bun run lint:all:fix"
  echo ""
  exit 1
fi

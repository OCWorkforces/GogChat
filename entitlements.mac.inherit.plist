<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Allow unsigned executable memory for V8 JavaScript engine (inherited by renderer) -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>

	<!-- Allow JIT compilation (inherited by renderer) -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>

	<!-- Disable library validation for child processes -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- Network access for renderer processes -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- USB device access inherited by child processes for WebAuthn -->
	<key>com.apple.security.device.usb</key>
	<true/>

	<!-- Bluetooth access inherited for wireless security keys -->
	<key>com.apple.security.device.bluetooth</key>
	<true/>
</dict>
</plist>

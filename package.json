{
  "name": "gogchat",
  "productName": "GogChat",
  "version": "3.16.1",
  "description": "GogChat is an unofficial macOS desktop wrapper for Google Chat, built with Electron and TypeScript.",
  "private": true,
  "repository": "https://github.com/OCWorkforces/GogChat",
  "homepage": "https://github.com/OCWorkforces/GogChat",
  "author": "OCWorkforces Engineers",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "main": "lib/main/index.js",
  "sideEffects": false,
  "scripts": {
    "prestart": "bun run build:prod",
    "start": "electron .",
    "clean:dist": "rimraf ./dist",
    "clean:lib": "rimraf ./lib",
    "build:dev": "bun scripts/build-rsbuild.js --dev",
    "build:prod": "bun scripts/build-rsbuild.js",
    "build:watch": "bun scripts/build-rsbuild.js --dev --watch",
    "build:analyze": "ANALYZE=true NODE_ENV=production bun scripts/build-rsbuild.js",
    "prets": "bun run clean:lib",
    "ts": "tsc",
    "package": "BUILD_ENV=${BUILD_ENV:-production} bun run build:prod && BUILD_ENV=${BUILD_ENV:-production} electron-builder --mac",
    "package:mac:release": "BUILD_ENV=${BUILD_ENV:-production} bun run build:prod && bun scripts/mac-release-signing.js --release && env -u MAC_CSC_LINK -u MAC_CSC_KEY_PASSWORD BUILD_ENV=${BUILD_ENV:-production} CSC_LINK=\"$MAC_CSC_LINK\" CSC_KEY_PASSWORD=\"$MAC_CSC_KEY_PASSWORD\" electron-builder --config electron-builder.sign.yml --mac --publish never",
    "package:win:x64": "bun run build:prod && electron-builder --config electron-builder.win.yml --win nsis:x64 --publish never",
    "package:win:arm64": "bun run build:prod && electron-builder --config electron-builder.win.yml --win nsis:arm64 --publish never",
    "package:win:artifacts": "bun scripts/verify-windows-package-artifacts.js --dist dist --manifest --require-arch x64 --require-arch arm64",
    "package:win:signing-policy": "bun scripts/verify-windows-signing-policy.js --release",
    "test": "node --require ./tests/polyfill-crypto.cjs ./node_modules/vitest/vitest.mjs",
    "test:ui": "node --require ./tests/polyfill-crypto.cjs ./node_modules/vitest/vitest.mjs --ui",
    "test:run": "node --require ./tests/polyfill-crypto.cjs ./node_modules/vitest/vitest.mjs run",
    "test:coverage": "node --require ./tests/polyfill-crypto.cjs ./node_modules/vitest/vitest.mjs run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"scripts/**/*.js\" --fix",
    "format": "prettier --check \"src/**/*.{ts,js,json}\" \"scripts/**/*.js\" \"*.{json,md}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,js,json}\" \"scripts/**/*.js\" \"*.{json,md}\"",
    "lint:all": "bash ./scripts/lint.sh",
    "lint:all:fix": "bash ./scripts/lint.sh --fix",
    "check:doc-claims": "bun scripts/check-doc-claims.js",
    "hooks:install": "bash ./scripts/install-hooks.sh",
    "pack:mac:arm64": "electron-builder --mac --arm64 --dir",
    "build:mac": "bash ./build-macOS-dmg.sh --environment production",
    "build:mac:dev": "bash ./build-macOS-dmg.sh --environment develop",
    "build:mac:arm64": "bash ./build-macOS-dmg.sh --environment production",
    "build:mac:arm64:dev": "bash ./build-macOS-dmg.sh --environment develop",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@rsbuild/core": "^2.1.6",
    "@rspack/core": "^2.1.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/auto-launch": "^5.0.5",
    "@types/throttle-debounce": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jsdom": "^29.1.1",
    "madge": "^8.0.0",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "sharp": "^0.35.3",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@rslib/core": "^0.23.2",
    "auto-launch": "^5.0.6",
    "electron-context-menu": "^4.1.2",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-unhandled": "^5.0.0",
    "electron-update-notifier": "^1.7.0",
    "throttle-debounce": "^5.0.2"
  },
  "engineStrict": true,
  "engines": {
    "node": ">=24.16.0 <25.0.0",
    "bun": ">=1.3.0"
  }
}

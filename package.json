{
  "name": "gchat",
  "productName": "Google Chat",
  "version": "3.2.5",
  "description": "Google Chat",
  "private": true,
  "repository": "https://github.com/CCWorkforce/GChat",
  "homepage": "https://github.com/CCWorkforce/GChat",
  "author": "CCWorkforce",
  "type": "module",
  "main": "lib/main/index.js",
  "scripts": {
    "prestart": "npm run build:prod",
    "start": "electron .",
    "clean:dist": "rimraf ./dist",
    "clean:lib": "rimraf ./lib",
    "build:dev": "node scripts/build-rsbuild.js --dev",
    "build:prod": "node scripts/build-rsbuild.js",
    "build:watch": "node scripts/build-rsbuild.js --dev --watch",
    "build:analyze": "cross-env ANALYZE=true NODE_ENV=production node scripts/build-rsbuild.js",
    "prets": "npm run clean:lib",
    "ts": "tsc",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"scripts/**/*.js\" --fix",
    "format": "prettier --check \"src/**/*.{ts,js,json}\" \"scripts/**/*.js\" \"*.{json,md}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,js,json}\" \"scripts/**/*.js\" \"*.{json,md}\"",
    "lint:all": "bash ./scripts/lint.sh",
    "lint:all:fix": "bash ./scripts/lint.sh --fix",
    "hooks:install": "bash ./scripts/install-hooks.sh",
    "prepack:mac": "npm run clean:dist && npm run build:prod",
    "pack:mac": "electron-packager . --platform=darwin --arch=x64 --asar --overwrite --out=./dist/ --icon=./resources/icons/normal/mac.icns --ignore='^/(src|.github|coverage|debian|mac|windows|.git|.vscode|.idea|tests|scripts)$' --ignore='\\.md$' --ignore='\\.map$' --ignore='\\.test\\.(ts|js)$' --ignore='(tsconfig\\.json|vitest\\.config\\.ts|playwright\\.config\\.ts|eslint\\.config\\.js|\\.prettierrc\\.json|\\.editorconfig|\\.npmrc|\\.gitignore|\\.gitattributes|\\.DS_Store|package-lock\\.json|entitlements\\.mac.*\\.plist)$'",
    "postpack:mac": "node scripts/remove-locales.js mac x64",
    "pack:mac-arm": "electron-packager . --platform=darwin --arch=arm64 --asar --overwrite --out=./dist/ --icon=./resources/icons/normal/mac.icns --ignore='^/(src|.github|coverage|debian|mac|windows|.git|.vscode|.idea|tests|scripts)$' --ignore='\\.md$' --ignore='\\.map$' --ignore='\\.test\\.(ts|js)$' --ignore='(tsconfig\\.json|vitest\\.config\\.ts|playwright\\.config\\.ts|eslint\\.config\\.js|\\.prettierrc\\.json|\\.editorconfig|\\.npmrc|\\.gitignore|\\.gitattributes|\\.DS_Store|package-lock\\.json|entitlements\\.mac.*\\.plist)$'",
    "postpack:mac-arm": "node scripts/remove-locales.js mac arm64",
    "build:mac-dmg": "bash ./mac/installer-dmg.sh",
    "build:mac-arm-dmg": "bash ./mac/installer-arm-dmg.sh"
  },
  "devDependencies": {
    "@electron/osx-sign": "^2.2.0",
    "@rsbuild/core": "^1.5.16",
    "@rspack/core": "^1.5.8",
    "@types/auto-launch": "^5.0.5",
    "@types/throttle-debounce": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "cross-env": "^10.1.0",
    "electron": "^38.2.2",
    "electron-packager": "^17.1.2",
    "esbuild": "^0.25.10",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-context-menu": "^4.1.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-unhandled": "^5.0.0",
    "electron-update-notifier": "^1.7.0",
    "throttle-debounce": "^5.0.2"
  },
  "engineStrict": true,
  "engines": {
    "node": ">=22.0.0"
  }
}

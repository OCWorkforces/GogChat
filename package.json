{
  "name": "gchat",
  "productName": "GChat",
  "version": "3.1.1",
  "description": "GChat",
  "private": true,
  "repository": "https://github.com/CCWorkforce/GChat",
  "homepage": "https://github.com/CCWorkforce/GChat",
  "author": "CCWorkforce",
  "main": "lib/main/index.js",
  "scripts": {
    "prestart": "npm run ts",
    "start": "electron .",
    "clean:dist": "rimraf ./dist",
    "clean:lib": "rimraf ./lib",
    "prets": "npm run clean:lib",
    "ts": "tsc",
    "build:dev": "node scripts/build.js --dev",
    "build:prod": "node scripts/build.js",
    "build:watch": "node scripts/build.js --dev --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"scripts/**/*.js\" --fix",
    "format": "prettier --check \"src/**/*.{ts,js,json}\" \"scripts/**/*.js\" \"*.{json,md}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,js,json}\" \"scripts/**/*.js\" \"*.{json,md}\"",
    "lint:all": "bash ./scripts/lint.sh",
    "lint:all:fix": "bash ./scripts/lint.sh --fix",
    "hooks:install": "bash ./scripts/install-hooks.sh",
    "prepack:windows": "npm run clean:dist && npm run build:prod",
    "pack:windows": "electron-packager . --platform=win32 --arch=x64 --asar --overwrite --out=./dist/ --icon=./resources/icons/normal/windows.ico --ignore='^/(src|.github|coverage|debian|mac|windows|.git|.vscode|.idea)$' --ignore='\\.md$' --ignore='\\.test\\.(ts|js)$' --ignore='(tsconfig\\.json|vitest\\.config\\.ts|\\.editorconfig|\\.npmrc|\\.gitignore|\\.gitattributes|\\.DS_Store|package-lock\\.json|entitlements\\.mac.*\\.plist)$'",
    "postpack:windows": "node scripts/remove-locales.js windows x64",
    "build:windows": "node ./windows/installer.js",
    "prepack:mac": "npm run clean:dist && npm run build:prod",
    "pack:mac": "electron-packager . --platform=darwin --arch=x64 --asar --overwrite --out=./dist/ --icon=./resources/icons/normal/mac.icns --ignore='^/(src|.github|coverage|debian|mac|windows|.git|.vscode|.idea)$' --ignore='\\.md$' --ignore='\\.test\\.(ts|js)$' --ignore='(tsconfig\\.json|vitest\\.config\\.ts|\\.editorconfig|\\.npmrc|\\.gitignore|\\.gitattributes|\\.DS_Store|package-lock\\.json|entitlements\\.mac.*\\.plist)$'",
    "postpack:mac": "node scripts/remove-locales.js mac x64",
    "pack:mac-arm": "electron-packager . --platform=darwin --arch=arm64 --asar --overwrite --out=./dist/ --icon=./resources/icons/normal/mac.icns --ignore='^/(src|.github|coverage|debian|mac|windows|.git|.vscode|.idea)$' --ignore='\\.md$' --ignore='\\.test\\.(ts|js)$' --ignore='(tsconfig\\.json|vitest\\.config\\.ts|\\.editorconfig|\\.npmrc|\\.gitignore|\\.gitattributes|\\.DS_Store|package-lock\\.json|entitlements\\.mac.*\\.plist)$'",
    "postpack:mac-arm": "node scripts/remove-locales.js mac arm64",
    "build:mac-zip": "bash ./mac/installer-zip.sh",
    "build:mac-dmg": "bash ./mac/installer-dmg.sh",
    "build:mac-arm-zip": "bash ./mac/installer-arm-zip.sh",
    "build:mac-arm-dmg": "bash ./mac/installer-arm-dmg.sh",
    "prepack:linux": "npm run clean:dist && npm run build:prod",
    "pack:linux": "electron-packager . --platform=linux --arch=x64 --asar --overwrite --out=./dist/ --ignore='^/(src|.github|coverage|debian|mac|windows|.git|.vscode|.idea)$' --ignore='\\.md$' --ignore='\\.test\\.(ts|js)$' --ignore='(tsconfig\\.json|vitest\\.config\\.ts|\\.editorconfig|\\.npmrc|\\.gitignore|\\.gitattributes|\\.DS_Store|package-lock\\.json|entitlements\\.mac.*\\.plist)$'",
    "postpack:linux": "node scripts/remove-locales.js linux x64",
    "build:deb": "electron-installer-debian --config=./debian/config.json --arch=amd64",
    "build:deb-checksum": "cd ./dist/installers && sha512sum *.deb > GChat-deb-SHA512.txt"
  },
  "devDependencies": {
    "@electron/osx-sign": "^2.2.0",
    "@types/auto-launch": "^5.0.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/throttle-debounce": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "electron": "^38.2.2",
    "electron-packager": "^17.1.2",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "better-sqlite3": "^12.4.1",
    "date-fns": "^4.1.0",
    "electron-context-menu": "^4.1.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-unhandled": "^5.0.0",
    "electron-update-notifier": "^1.7.0",
    "esbuild": "^0.25.10",
    "throttle-debounce": "^5.0.2"
  },
  "optionalDependencies": {
    "electron-installer-debian": "^3.2.0"
  },
  "engineStrict": true,
  "engines": {
    "node": ">=22.0.0"
  }
}
